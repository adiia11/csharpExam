    public class NutritionLogic
    {
        /// <summary>
        ///  принаймі 1 перевищує норму
        /// </summary>
        /// <param name="patiens"></param> Patient: Id,LastName,CarbsNorm,ProteinsNorm,FatsNorm
        /// <param name="products"></param> Id, Name,CarbsPr,ProteinsPr,FatsPr
        /// <returns></returns> Date("yyyy-MM-dd"),PatientId,ProductId,WeightCons
        /// flDt={PatientLN,Date,ProductN,
        ///secondMerge=>get sum and compare
       public static XElement GetPatientStatistic(IEnumerable<XElement> patients, IEnumerable<XElement> products, IEnumerable<XElement> infos)
        {
            var flatData = from i in infos
                           join pt in patients on (int)i.Element("PatientId")! equals (int)pt.Element("Id")!
                           join pr in products on (int)i.Element("ProductId")! equals (int)pr.Element("Id")!
                           select new
                           {
                               PatientLN = (string)pt.Element("LastName")!,
                               Date = (DateTime)i.Element("Date")!,
                               DayCarbAm = (decimal)i.Element("WeightCons")! * (decimal)pr.Element("CarbsPr")!,
                               DayPrAm = (decimal)i.Element("WeightCons")! * (decimal)pr.Element("ProteinsPr")!,
                               DayFtAm = (decimal)i.Element("WeightCons")! * (decimal)pr.Element("FatsPr")!,
                               CarbsNorm = (decimal)pt.Element("CarbsNorm")!,
                               ProteinsNorm = (decimal)pt.Element("ProteinsNorm")!,
                               FatsNorm = (decimal)pt.Element("FatsNorm")!
                           };
            var eachPatient = from f in flatData
                              group f by new { f.PatientLN, f.Date } into PatGr
                              let SumCarbs = PatGr.Sum(x => x.DayCarbAm)
                              let SumProteins = PatGr.Sum(x => x.DayPrAm)
                              let SumFats = PatGr.Sum(x => x.DayFtAm)
                              let patient = PatGr.First()
                              where SumCarbs>patient.CarbsNorm || SumProteins>patient.ProteinsNorm||SumFats>patient.FatsNorm
                              select new
                              {
                                  PatientLastName = PatGr.Key.PatientLN,
                                  DatePt = PatGr.Key.Date
                              };
            var finalMerge = from e in eachPatient
                             group e by e.PatientLastName into PtGroup
                             orderby PtGroup.Key ascending
                             select new XElement("Patients",
                            new XElement("Patient", PtGroup.Key),
                            from p in PtGroup
                            orderby p.DatePt ascending
                            select new XElement("Date", p.DatePt.ToString("yyyy-MM-dd"))
                             );
            return new XElement("PatientStat", finalMerge);

        }
        /// <summary>
        /// flatDat=> PrName,for each PR (x=>x.WeightCons) patient=>persWeight=Max(x=>x.WeightCons)
        /// </summary>
        /// <param name="patients"></param>
        /// <param name="products"></param>
        /// <param name="infos"></param>
        /// <returns></returns>
        public static XElement GetProductStat(IEnumerable<XElement> patients, IEnumerable<XElement> products, IEnumerable<XElement> infos)
        {
            var flatData = from i in infos
                           join pt in patients on (int)i.Element("PatientId")! equals (int)pt.Element("Id")!
                           join pr in products on (int)i.Element("ProductId")! equals (int)pr.Element("Id")!
                           select new
                           {
                               PtLastName = (string)pt.Element("LastName")!,
                               PrName = (string)pr.Element("Name")!,
                               WeightCons = (decimal)i.Element("WeightCons")!
                           };
            var eachProduct = from f in flatData
                              group f by new { f.PrName, f.PtLastName } into ProductGroup
                              let PerCons = ProductGroup.Sum(x => x.WeightCons)
                              select new
                              {
                                  PatLastName = ProductGroup.Key.PtLastName,
                                  ProdName = ProductGroup.Key.PrName,
                                  PersonalConWg = PerCons
                              };
            var finalMerge = from e in eachProduct
                             group e by e.ProdName into ProductNGr
                             orderby ProductNGr.Key ascending
                             let TotalGrWeight = ProductNGr.Sum(x => x.PersonalConWg)
                             let MaxConPer = ProductNGr.Max(x => x.PersonalConWg)
                             
                             select new XElement("Product",
                             new XElement("Name", ProductNGr.Key),
                             new XElement("TotalConsumedGrWeight", TotalGrWeight),
                             from p in ProductNGr
                            
                 
                              where p.PersonalConWg == MaxConPer
                              orderby p.PatLastName ascending
                             select new XElement("Patient",
                             new XElement("LastName", p.PatLastName),
                             new XElement("MaxConsu", p.PersonalConWg)
                             )

                           );
            return new XElement("ProductStat", finalMerge);
        }
    }

    public class Program
    {
        public static void Main(string[] args)
        {
            var patients = XDocument.Load("patients.xml").Descendants("Patient");
            var products = XDocument.Load("products.xml").Descendants("Product");
            var info1 = XDocument.Load("info1.xml").Descendants("Info");
            var info2 = XDocument.Load("info2.xml").Descendants("Info");
            var infos = info1.Concat(info2);
            var taskA = NutritionLogic.GetPatientStatistic(patients, products, infos);
            var taskB = NutritionLogic.GetProductStat(patients, products, infos);
