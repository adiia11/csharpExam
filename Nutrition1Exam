            string pathB = "D:\\Users\\LEGEND\\source\\repos\\NutritionExam\\NutritionExam\\TaskB.xml";
            taskA.Save(pathA);
            taskB.Save(pathB);
            Console.WriteLine(taskA.ToString());
            Console.WriteLine(taskB.ToString());

        }
    }
